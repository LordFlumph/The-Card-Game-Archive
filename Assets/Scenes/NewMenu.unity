  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: '1. Do stuff good

    2. Don''t do stuff bad

    3. Win

    4. ?

    5.
    ???

    6. um?

    7. Why is it still going?

    8. ...

    9. ...

    10.
    Help?

    11. Guys please

    12. Let me out, there aren''t any more instructions

    13.
    How do I leave???

    14. Reader, are you still there?

    15. I need you to
    help me

    16. If you do then you can be a friend of mine

    17. ...

    18.
    Not enough huh?

    19. Fine, I know the secret steps to wining, i''ll tell
    you if you agree

    20. Ok?

    21. Don''t keep reading if you don''t agree

    22.
    ...

    23. Alright, I''m going to assume you agreed, I can''t actually see
    you or anything

    24. So, here are the steps

    25. 1. Get a card

    26.
    2. Rip it to shreds

    27. 3. ???

    28. 4. ???

    29. 5. ???

    30.
    6. ???

    31. 7. Profit'
